{
    "layer": "top",
    "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher","wlr/taskbar","hyprland/window"],
        "modules-center": ["custom/mpris","custom/cava","wlr/workspaces"],
        "modules-right": ["tray","backlight", "battery", "clock"],

        "pulseaudio": {
            "format": "{volume}% {icon}",
            "format-bluetooth": "{volume}% {icon}",
            "format-muted": "",
            "format-icons": {
                "default": ["", ""]
            },
            "scroll-step": 1,
            "on-click": "pavucontrol",
            "ignored-sinks": ["Easy Effects Sink"]
        },
        
        "custom/launcher":{
            "format": "  ",
            "on-click": "rofi -combi-modi drun -show combi -icon-theme 'Papirus' -show-icons",
            "on-click-right": "killall rofi"
        },

        "custom/mpris":{
            "format": "⏯",
            "on-click": "playerctl play-pause",
            "on-click-right": "playerctl next",
            "on-click-middle": "playerctl previous",
        },

        "mpris": {
            "max-length": 10,
            "format": "{player_icon}",
            "format-paused": "{status_icon}",
            "player-icons": {
                "default": "▶",
                "mpv": "🎵"
            },
            "status-icons": {
                "paused": "⏸"
            },
            "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": " {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": " {}%",
            "max-length": 10,
        },

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 22,
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        "custom/cava": {
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/▁/g;s/1/▂/g;s/2/▃/g;s/3/▄/g;s/4/▅/g;s/5/▆/g;s/6/▇/g;s/7/█/g;'",
            "tooltip": false
            },

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon}",
            "format-icons": ["", "", "", "", "", "", "", "", ""],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "killall swaybg && swaybg -i $(find ~/PICTURES/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-charging": " {capacity}%",
            "format-plugged": " {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["", "", "", "", ""]
        },

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon} {format_source}",
            "format-bluetooth-muted": " {icon} {format_source}",
            "format-muted": " {format_source}",
            "format-source": "{volume}% ",
            "format-source-muted": "",
            "format-icons": {
                "headphone": "",
                "hands-free": "",
                "headset": "",
                "phone": "",
                "portable": "",
                "car": "",
                "default": ["", "", ""]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%m月%d日 周%a %H:%M}", 
            "tooltip" : true, 
            "tooltip-format" : "<tt>{calendar}</tt>",
        }
},
