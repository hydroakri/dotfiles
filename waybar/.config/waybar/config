{
    "layer": "top",
        "height": 28,
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "spacing": 2,
        "modules-left": ["wlr/taskbar","wlr/workspaces", "custom/cava-internal"],
        "modules-center": ["clock"],
        "modules-right": ["backlight", "battery", "tray"],

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 22,
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        "custom/cava-internal": {
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/вЦБ/g;s/1/вЦВ/g;s/2/вЦГ/g;s/3/вЦД/g;s/4/вЦЕ/g;s/5/вЦЖ/g;s/6/вЦЗ/g;s/7/вЦИ/g;'",
            "tooltip": false
            },

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{percent}% {icon}",
            "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
        },

        "battery": {
            "interval": 10,
          "states": {
            "warning": 20,
            "critical": 10,
          },
          "format": "{icon} {capacity}%",
          "format-icons": [ "пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пЦА", "пЦБ", "пХЄ", ],
          "format-full": "{icon} {capacity}%",
          "format-charging": "пЦГ {capacity}%",
          "tooltip": false,
        },

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
            "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
            "format-muted": "пЪ© {format_source}",
            "format-source": "{volume}% пД∞",
            "format-source-muted": "пД±",
            "format-icons": {
                "headphone": "пА•",
                "hands-free": "пЦР",
                "headset": "пЦР",
                "phone": "пВХ",
                "portable": "пВХ",
                "car": "пЖє",
                "default": ["пА¶", "пАІ", "пА®"]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%I:%M %p  %A %b %d}", 
            "tooltip" : true, 
            "tooltip-format" : "<tt>{calendar}</tt>",
        }
}
