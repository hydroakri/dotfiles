{
    "layer": "top",
    "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher","wlr/taskbar","hyprland/window"],
        "modules-center": ["mpris","wlr/workspaces"],
        "modules-right": ["tray","backlight", "battery", "clock"],

        "pulseaudio": {
            "format": "{volume}% {icon}",
            "format-bluetooth": "{volume}% {icon}яКФ",
            "format-muted": "яАж",
            "format-icons": {
                "default": ["яАз", "яАи"]
            },
            "scroll-step": 1,
            "on-click": "pavucontrol",
            "ignored-sinks": ["Easy Effects Sink"]
        },
        
        "custom/launcher":{
            "format": " яМГ ",
            "on-click": "rofi -combi-modi drun -show combi -icon-theme 'Papirus' -show-icons",
            "on-click-right": "killall rofi"
        },

        "custom/mpris":{
            "format": "тПп",
            "on-click": "playerctl play-pause",
            "on-click-right": "playerctl next",
            "on-click-middle": "playerctl previous",
        },

        "mpris": {
        	"format": "{player_icon} {title}",
        	"format-paused": "{status_icon} <i>{title}</i>",
        	"player-icons": {
        		"default": "тЦ╢",
        		"mpv": "ЁЯО╡"
        	},
        	"status-icons": {
        		"paused": "тП╕"
        	},
        	// "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": "яЛЫ {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": "яГЙ {}%",
            "max-length": 10,
        },

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 22,
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        /* "custom/cava": { */
        /*     "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/тЦБ/g;s/1/тЦВ/g;s/2/тЦГ/g;s/3/тЦД/g;s/4/тЦЕ/g;s/5/тЦЖ/g;s/6/тЦЗ/g;s/7/тЦИ/g;'", */
        /*     "tooltip": false */
        /*     }, */

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon}",
            "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "killall swaybg && swaybg -i $(find ~/PICTURES/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-charging": "яЗж {capacity}%",
            "format-plugged": "яЗж {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        },

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
            "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
            "format-muted": "яЪй {format_source}",
            "format-source": "{volume}% яД░",
            "format-source-muted": "яД▒",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАж", "яАз", "яАи"]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%mцЬИ%dцЧе хСи%a %H:%M}", 
            "tooltip" : true, 
            "tooltip-format" : "<tt>{calendar}</tt>",
        }
},
