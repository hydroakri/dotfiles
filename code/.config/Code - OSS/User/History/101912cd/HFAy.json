// 将键绑定放在此文件中以覆盖默认值auto[]
[
    {
        "key": "ctrl+shift+w",
        "command": "-workbench.action.closeWindow"
    },
    {
        "key": "s",
        "command": "editor.debug.action.closeExceptionWidget",
        "when": "exceptionWidgetVisible"
    },
    {
        "key": "escape",
        "command": "-editor.debug.action.closeExceptionWidget",
        "when": "exceptionWidgetVisible"
    }
]