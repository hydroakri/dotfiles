{
    "layer": "top",
    "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher","wlr/taskbar","hyprland/window"],
        "modules-center": ["mpris","custom/cava","wlr/workspaces"],
        "modules-right": ["pulseaudio","backlight", "battery","tray", "clock"],

        "pulseaudio": {
            "format": "{volume}% {icon}",
            "format-bluetooth": "{volume}% {icon}пЉ”",
            "format-muted": "пЂ¦",
            "format-icons": {
                "default": ["пЂ§", "пЂЁ"]
            },
            "scroll-step": 1,
            "on-click": "pavucontrol",
            "ignored-sinks": ["Easy Effects Sink"]
        },
        
        "custom/launcher":{
            "format": " пЊѓ ",
            "on-click": "rofi -combi-modi drun -show combi -icon-theme 'Papirus' -show-icons",
            "on-click-right": "killall rofi"
        },

        "mpris": {
            "max-length": 10,
            "format": "{player_icon}",
            "format-paused": "{status_icon}",
            "player-icons": {
                "default": "в–¶",
                "mpv": "рџЋµ"
            },
            "status-icons": {
                "paused": "вЏё"
            },
            // "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": "п‹› {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": "пѓ‰ {}%",
            "max-length": 10,
        },

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 22,
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        "custom/cava": {
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/в–Ѓ/g;s/1/в–‚/g;s/2/в–ѓ/g;s/3/в–„/g;s/4/в–…/g;s/5/в–†/g;s/6/в–‡/g;s/7/в–€/g;'",
            "tooltip": false
            },

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{percent}% {icon}",
            "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
        },

        "battery": {
            "interval": 10,
          "states": {
            "warning": 20,
            "critical": 10,
          },
          "format": "{icon} {capacity}%",
          "format-icons": [ "п•№", "п•є", "п•»", "п•ј", "п•Ѕ", "п•ѕ", "п–Ђ", "п–Ѓ", "п•ё", ],
          "format-full": "{icon} {capacity}%",
          "format-charging": "п–ѓ {capacity}%",
          "tooltip": false,
          "on-click": "killall swaybg && swaybg -i $(find ~/PICTURES/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
            "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
            "format-muted": "пљ© {format_source}",
            "format-source": "{volume}% п„°",
            "format-source-muted": "п„±",
            "format-icons": {
                "headphone": "пЂҐ",
                "hands-free": "п–ђ",
                "headset": "п–ђ",
                "phone": "п‚•",
                "portable": "п‚•",
                "car": "п†№",
                "default": ["пЂ¦", "пЂ§", "пЂЁ"]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%A %b %d %H:%M}", 
            "tooltip" : true, 
            "tooltip-format" : "<tt>{calendar}</tt>",
        }
},
