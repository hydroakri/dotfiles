{
    "layer": "top",
        "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher", "tray","mpris","cava","custom/cava"],
        "modules-center": ["wlr/workspaces"],
        "modules-right": ["custom/mako", "wireplumber", "backlight", "battery", "clock",],

        "custom/mako": {
            "format": "яС╢ ",
            "on-click": "makoctl mode -a do-not-disturb",
            "on-click-right": "makoctl mode -r do-not-disturb",
            "on-click-middle": "makoctl restore",
        },

        "wireplumber": {
            "format": "{icon} {volume}%",
            "format-bluetooth": "{icon}яКФ {volume}%",
            "format-muted": "яАж",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАз", "яАи"]
            },
            "on-click": "pavucontrol",
            "max-volume": 150,
            "scroll-step": 1
        },

        "custom/launcher":{
            "format": "яМГ ",
            "on-click": "wofi --show run",
            "on-click-right": "killall rofi"
        },

        "mpris": {
            "max-length": 25,
            "format": "{player_icon} {title}",
            "format-paused": "{status_icon} <i>{title}</i>",
            "player-icons": {
                "default": "тЦ╢",
                "mpv": "ЁЯО╡"
            },
            "status-icons": {
                "paused": "тП╕"
            },
            // "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": "яЛЫ {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": "яГЙ {}%",
            "max-length": 10,
        },

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        "hyprland/window": {
            "max-length": 20
        },

        "cava": {
            "cava_config": "$XDG_CONFIG_HOME/cava/conf_for_bar",
            "framerate": 30,
            "autosens": 1,
            "sensitivity": 100,
            "bars": 14,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons" : ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
            "actions": {
                "on-click-right": "mode"
            }
        },

        "custom/cava": { 
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/тЦБ/g;s/1/тЦВ/g;s/2/тЦГ/g;s/3/тЦД/g;s/4/тЦЕ/g;s/5/тЦЖ/g;s/6/тЦЗ/g;s/7/тЦИ/g;'", 
            "tooltip": false 
        }, 

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon} {percent}%",
            "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "killall swaybg && swaybg -i $(find ~/Pictures/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-charging": "яЗж {capacity}%",
            "format-plugged": "яЗж {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        },

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
            "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
            "format-muted": "яЪй {format_source}",
            "format-source": "{volume}% яД░",
            "format-source-muted": "яД▒",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАж", "яАз", "яАи"]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%H:%M}", 
            "format-alt": "{:%m-%d Week %a }",
        }
},
