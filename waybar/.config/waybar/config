{
        "layer": "top",
        "exclusive": "false",
        "reload_style_on_change": true,
        "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
        //"modules-left": ["custom/launcher",],
        "modules-center": ["mpris"],
        "modules-right": ["gamemode","custom/mako", "backlight", "wireplumber", "tray", "battery", "clock",],

        "hyprland/window": {
            "format": "{}",
            "rewrite": {
                "(.*) έΑΦ Mozilla Firefox": "ΏθΝΟ $1",
                "(.*) - foot": "> [$1]"
            },
            "separate-outputs": true,
            "max-length": 25,
        },

        "hyprland/workspaces": {
            "show-special": true,
            "persistent_workspaces": {
                "eDP-1": [ 1, 2, 3, 4, 5 ], // workspace 1 shown on DP-3
            },
            "format": "{icon}",
            "format-icons": {
                "1": "≤░▓ι ",
                "2": "≤░▓λ ",
                "3": "≤░▓ν ",
                "4": "≤░▓ο ",
                "5": "≤░▓ρ ",
                "special": "ΎΕ║ ",
            },
        },

        "gamemode": {
            "format": "{glyph}",
            "format-alt": "{glyph} {count}",
            "glyph": "≤░ΛΩ ",
            "hide-not-running": true,
            "use-icon": true,
            "icon-name": "input-gaming-symbolic",
            "icon-spacing": 4,
            "icon-size": 20,
            "tooltip": true,
            "tooltip-format": "Games running: {count}",
        },

        "custom/mako": {
            "format": "ΎΣ╢ ",
            "on-click": "notify-send 'no disturb on' && sleep 1 && makoctl mode -a do-not-disturb",
            "on-click-right": "makoctl mode -r do-not-disturb && sleep 1 && notify-send 'no disturb off'",
            "on-click-middle": "makoctl restore",
        },

        "wireplumber": {
            "format": "{icon}",
            "format-bluetooth": "{icon}ΎΛΦ {volume}%",
            "format-muted": "ΎΑο",
            "format-icons": {
                "headphone": "ΎΑξ",
                "hands-free": "ΎΨΡ",
                "headset": "ΎΨΡ",
                "phone": "ΎΓΧ",
                "portable": "ΎΓΧ",
                "car": "ΎΗ╣",
                "default": ["ΎΑπ", "ΎΑρ"]
            },
            "on-click": "pavucontrol",
            "max-volume": 150,
            "scroll-step": 1
        },

        "custom/launcher":{
            "format": "≤░Ν╜ ",
            "on-click": "nwgbar",
        },

        "mpris": {
            "max-length": 25,
            "format": "{player_icon} {title}",
            "format-paused": "{status_icon} <i>{title}</i>",
            "player-icons": {
                "default": "έΨ╢",
                "mpv": "ΏθΟ╡"
            },
            "status-icons": {
                "paused": "έΠ╕"
            },
            // "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": "ΎΜδ {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": "ΎΔΚ {}%",
            "max-length": 10,
        },

        "cava": {
            //"cava_config": "~/.config/cava/conf_for_bar",
            "framerate": 30,
            "autosens": 1,
            "sensitivity": 100,
            "bars": 14,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons" : ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ" ],
            "actions": {
                "on-click-right": "mode"
            }
        },

        "custom/cava": { 
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/έΨΒ/g;s/1/έΨΓ/g;s/2/έΨΔ/g;s/3/έΨΕ/g;s/4/έΨΖ/g;s/5/έΨΗ/g;s/6/έΨΘ/g;s/7/έΨΙ/g;'", 
            "tooltip": false 
        }, 

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon}",
            "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "~/script/chgwllpr.sh",
            //"on-click": "killall swaybg && swaybg -i $(find ~/Pictures/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-plugged": "ΎΚΑ  {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        },

        "tray": {
            "icon-size": 20,
            "spacing": 5,
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%H:%M}", 
            "format-alt": "{:%m-%d %a }",
        }
},
