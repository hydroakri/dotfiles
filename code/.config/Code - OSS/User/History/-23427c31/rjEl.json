{
    "editor.fontFamily": "'IBM Plex Mono'",
    "editor.cursorStyle": "block",
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "workbench.iconTheme": "material-icon-theme",
    "editor.stickyScroll.enabled": true,
    "files.autoSave": "afterDelay",
    //vim config
    "vim.leader": "<space>",
    "vim.normalModeKeyBindings": [
        {
            "before": ["t"],
            "commands": ["workbench.action.toggleSidebarVisibility",],
        },
        {
            "before": ["<leader>","\\"],
            "commands": ["workbench.action.splitEditor",],
        },
        {
            "before": ["<leader>","-"],
            "commands": ["workbench.action.splitEditorOrthogonal",],
        },
        {
            "before": ["<leader>","g"],
            "commands": ["search.action.openNewEditorToSide",],
        },
        {
            "before": ["<S-j>",],
            "commands": ["workbench.action.previousEditor",],
        },
        {
            "before": ["<S-k>",],
            "commands": ["workbench.action.nextEditor",],
        },
        {
            "before": ["<leader>","q"],
            "commands": ["workbench.action.closeActiveEditor",],
        },
        {
            "before": ["<leader>","o"],
            "commands": ["workbench.action.toggleAuxiliaryBar",],
        },
        {
            "before": ["<leader>","x"],
            "commands": ["workbench.actions.view.problems",],
        },
        {
            "before": ["<leader>","f"],
            "commands": ["workbench.action.quickOpen",],
        },
    ],
    "workbench.colorTheme": "Catppuccin Latte",
    "editor.minimap.size": "fill",
    "editor.minimap.showSlider": "always",
    "window.zoomLevel": 1,
    "editor.minimap.renderCharacters": false,
    "vim.cursorStylePerMode.insert": "line-thin",
    "vim.easymotion": true,
    "indentRainbow.indicatorStyle": "light",
    "leetcode.endpoint": "leetcode-cn",
    "leetcode.defaultLanguage": "cpp",
    "leetcode.workspaceFolder": "/home/hydroakri/.leetcode",
    "leetcode.hint.configWebviewMarkdown": false,
    "leetcode.showDescription": "Both",
    "leetcode.hint.commentDescription": false,
    "leetcode.hint.commandShortcut": false,
    "editor.fontLigatures": true,
    "workbench.editor.untitled.hint": "hidden",
}