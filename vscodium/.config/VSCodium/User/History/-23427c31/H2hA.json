{
    "editor.fontFamily": "'Sarasa Mono SC Nerd'",
    "editor.cursorStyle": "block",
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "workbench.iconTheme": "material-icon-theme",
    "window.zoomLevel": 1,
    "editor.stickyScroll.enabled": true,
    "files.autoSave": "afterDelay",
    "editor.codeActionsOnSave": {
    
    },
    //vim config
    "vim.leader": "<space>",
    "vim.normalModeKeyBindings": [
        {
            "before": ["<leader>","t"],
            "commands": ["workbench.action.toggleSidebarVisibility",],
        },
        {
            "before": ["<leader>","\\"],
            "commands": ["workbench.action.splitEditor",],
        },
        {
            "before": ["<leader>","-"],
            "commands": ["workbench.action.splitEditorOrthogonal",],
        },
        {
            "before": ["<leader>","g"],
            "commands": ["search.action.openNewEditorToSide",],
        },
        {
            "before": ["<S-j>",],
            "commands": ["workbench.action.previousEditor",],
        },
        {
            "before": ["<S-k>",],
            "commands": ["workbench.action.nextEditor",],
        },
        {
            "before": ["<leader>","q"],
            "commands": ["workbench.action.closeActiveEditor",],
        },
        {
            "before": ["<leader>","o"],
            "commands": ["workbench.action.toggleAuxiliaryBar",],
        },
        {
            "before": ["<leader>","x"],
            "commands": ["workbench.actions.view.problems",],
        },
        {
            "before": ["<leader>","f"],
            "commands": ["workbench.action.quickOpen",],
        },
    ],
    "workbench.colorTheme": "Sweet Dracula",
}