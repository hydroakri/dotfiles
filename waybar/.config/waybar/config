{
    "layer": "top",
        "height": 36,
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "spacing": 2,
        "modules-left": ["wlr/workspaces", "clock","backlight", "battery"],
        "modules-center": ["wlr/taskbar"],
        "modules-right": ["tray"],

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
            "format-icons": {
                "1": "пД†",
                "2": "пЙ®",
                "3": "пД°",
                "4": "пЖЉ",
                "5": "пБµ",
                "urgent": "пБ™",
                "active": "пЖТ",
                "default": "пДС"
            },
            "sort-by-number": true
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 32,
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

            "backlight": {
                // "device": "amdgpu_bl1",
                "format": "{percent}% {icon}",
                "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
            },

            "battery": {
                "format": "{capacity}% {icon}",
                "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
            },

            "tray": {
                // "icon-size": 21,
                "spacing": 10
            },

            "pulseaudio": {
                // "scroll-step": 1, // %, can be a float
                "format": "{volume}% {icon} {format_source}",
                "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
                "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
                "format-muted": "пЪ© {format_source}",
                "format-source": "{volume}% пД∞",
                "format-source-muted": "пД±",
                "format-icons": {
                    "headphone": "пА•",
                    "hands-free": "пЦР",
                    "headset": "пЦР",
                    "phone": "пВХ",
                    "portable": "пВХ",
                    "car": "пЖє",
                    "default": ["пА¶", "пАІ", "пА®"]
                },
                "on-click": "pavucontrol"
            },

            "clock": {
                "calendar-weeks-pos": "right",
                "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
                "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
                "format-calendar-weeks": "<span color='#99ffdd'><b>W{:%U}</b></span>",
                "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "on-scroll": {
                    "clendar": 1
                }
            }
}
