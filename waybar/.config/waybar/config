{
    "layer": "top",
        "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher", "tray","mpris","cava","custom/cava"],
        "modules-center": ["wlr/workspaces"],
        "modules-right": ["gamemode","custom/mako", "wireplumber", "backlight", "battery", "clock",],

        "gamemode": {
            "format": "{glyph}",
            "format-alt": "{glyph} {count}",
            "glyph": "󰊗 ",
            "hide-not-running": true,
            "use-icon": true,
            "icon-name": "input-gaming-symbolic",
            "icon-spacing": 4,
            "icon-size": 20,
            "tooltip": true,
            "tooltip-format": "Games running: {count}",
        },

        "custom/mako": {
            "format": " ",
            "on-click": "makoctl mode -a do-not-disturb",
            "on-click-right": "makoctl mode -r do-not-disturb",
            "on-click-middle": "makoctl restore",
        },

        "wireplumber": {
            "format": "{icon} {volume}%",
            "format-bluetooth": "{icon} {volume}%",
            "format-muted": "",
            "format-icons": {
                "headphone": "",
                "hands-free": "",
                "headset": "",
                "phone": "",
                "portable": "",
                "car": "",
                "default": ["", ""]
            },
            "on-click": "pavucontrol",
            "max-volume": 150,
            "scroll-step": 1
        },

        "custom/launcher":{
            "format": " ",
            "on-click": "nwgbar",
        },

        "mpris": {
            "max-length": 25,
            "format": "{player_icon} {title}",
            "format-paused": "{status_icon} <i>{title}</i>",
            "player-icons": {
                "default": "▶",
                "mpv": "🎵"
            },
            "status-icons": {
                "paused": "⏸"
            },
            // "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": " {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": " {}%",
            "max-length": 10,
        },

        "wlr/workspaces": {
            "format": "{icon}",
            "on-click": "activate",
        },

        "wlr/taskbar": {
            "format": "{icon}",
            "icon-theme": "Papirus",
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close",
            "ignore-list": [
                "Alacritty"
            ],
            "app_ids-mapping": {
                "firefoxdeveloperedition": "firefox-developer-edition"
            }
        },

        "hyprland/window": {
            "max-length": 20
        },

        "cava": {
            "cava_config": "$XDG_CONFIG_HOME/cava/conf_for_bar",
            "framerate": 30,
            "autosens": 1,
            "sensitivity": 100,
            "bars": 14,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons" : ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
            "actions": {
                "on-click-right": "mode"
            }
        },

        "custom/cava": { 
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/▁/g;s/1/▂/g;s/2/▃/g;s/3/▄/g;s/4/▅/g;s/5/▆/g;s/6/▇/g;s/7/█/g;'", 
            "tooltip": false 
        }, 

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon} {percent}%",
            "format-icons": ["", "", "", "", "", "", "", "", ""],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "killall swaybg && swaybg -i $(find ~/Pictures/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-charging": " {capacity}%",
            "format-plugged": " {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["", "", "", "", ""],
            "on-click": "killall swayidle",
            "on-click-right": "swayidle -w timeout 300 'hyprctl dispatch dpms off' resume 'hyprctl dispatch dpms on' timeout 600 'swaylock -f -c 000000' before-sleep 'swaylock -c 000000 -f'",
        },

        "tray": {
            // "icon-size": 21,
        },

        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon} {format_source}",
            "format-bluetooth-muted": " {icon} {format_source}",
            "format-muted": " {format_source}",
            "format-source": "{volume}% ",
            "format-source-muted": "",
            "format-icons": {
                "headphone": "",
                "hands-free": "",
                "headset": "",
                "phone": "",
                "portable": "",
                "car": "",
                "default": ["", "", ""]
            },
            "on-click": "pavucontrol"
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%H:%M}", 
            "format-alt": "{:%m-%d %a }",
        }
},
