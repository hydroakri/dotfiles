{
    "layer": "top",
        "exclusive": "false",
        "position": "top",
        "margin-left": 0,
        "margin-right": 0,
        "margin-top": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
        //"modules-left": ["custom/launcher",],
        "modules-center": ["mpris"],
        "modules-right": ["gamemode","custom/mako", "backlight", "wireplumber", "tray", "battery", "clock",],

        "hyprland/window": {
            "format": "{}",
            "rewrite": {
                "(.*) тАФ Mozilla Firefox": "ЁЯМО $1",
                "(.*) - foot": "> [$1]"
            },
            "separate-outputs": true,
            "max-length": 25,
        },

        "hyprland/workspaces": {
            "persistent_workspaces": {
                "1": [],
                "2": [],
                "3": [],
                "4": ["eDP-1"],
                "5": ["eDP-1", "DP-2"]
            },
            "format": "{icon}",
            "format-icons": {
                "1": "яТк ",
                "2": "яТк ",
                "3": "яТк ",
                "4": "яТк ",
                "5": "яТк ",
                "active": "яДС ",
                "default": "яТк "
            },
        },

        "gamemode": {
            "format": "{glyph}",
            "format-alt": "{glyph} {count}",
            "glyph": "ґ░КЧ ",
            "hide-not-running": true,
            "use-icon": true,
            "icon-name": "input-gaming-symbolic",
            "icon-spacing": 4,
            "icon-size": 20,
            "tooltip": true,
            "tooltip-format": "Games running: {count}",
        },

        "custom/mako": {
            "format": "яС╢ ",
            "on-click": "notify-send 'no disturb on' && sleep 1 && makoctl mode -a do-not-disturb",
            "on-click-right": "makoctl mode -r do-not-disturb && sleep 1 && notify-send 'no disturb off'",
            "on-click-middle": "makoctl restore",
        },

        "wireplumber": {
            "format": "{icon}",
            "format-bluetooth": "{icon}яКФ {volume}%",
            "format-muted": "яАж",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАз", "яАи"]
            },
            "on-click": "pavucontrol",
            "max-volume": 150,
            "scroll-step": 1
        },

        "custom/launcher":{
            "format": "яМГ ",
            "on-click": "nwgbar",
        },

        "mpris": {
            "max-length": 25,
            "format": "{player_icon} {title}",
            "format-paused": "{status_icon} <i>{title}</i>",
            "player-icons": {
                "default": "тЦ╢",
                "mpv": "ЁЯО╡"
            },
            "status-icons": {
                "paused": "тП╕"
            },
            // "ignored-players": ["firefox"]
        },

        "cpu": {
            "interval": 15,
            "format": "яЛЫ {}%",
            "max-length": 10
        },

        "memory": {
            "interval": 30,
            "format": "яГЙ {}%",
            "max-length": 10,
        },

        "cava": {
            //"cava_config": "~/.config/cava/conf_for_bar",
            "framerate": 30,
            "autosens": 1,
            "sensitivity": 100,
            "bars": 14,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
            "bar_delimiter": 0,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons" : ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
            "actions": {
                "on-click-right": "mode"
            }
        },

        "custom/cava": { 
            "exec": "sleep 1s && cava -p ~/.config/cava/conf_for_bar | sed -u 's/;//g;s/0/тЦБ/g;s/1/тЦВ/g;s/2/тЦГ/g;s/3/тЦД/g;s/4/тЦЕ/g;s/5/тЦЖ/g;s/6/тЦЗ/g;s/7/тЦИ/g;'", 
            "tooltip": false 
        }, 

        "backlight": {
            // "device": "amdgpu_bl1",
            "format": "{icon}",
            "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "on-click": "~/script/chgwllpr.sh",
            //"on-click": "killall swaybg && swaybg -i $(find ~/Pictures/wllppr/. -name '*.*g' | shuf -n1) -m fill",
        },

        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-plugged": "яЙА  {capacity}%",
            "format-alt": "{time} {icon}",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        },

        "tray": {
            "icon-size": 20,
            "spacing": 5,
        },

        "clock": {
            "interval" : 1, 
            "format" : "{:%H:%M}", 
            "format-alt": "{:%m-%d %a }",
        }
},
